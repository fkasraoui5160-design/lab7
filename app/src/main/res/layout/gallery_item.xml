<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="?android:attr/selectableItemBackground">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/profilePhoto"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@android:drawable/btn_star_big_on"
        app:civ_border_width="2dp"
        app:civ_border_color="#FFD700" />

    <TextView
        android:id="@+id/celebrityName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/profilePhoto"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:text="Nom de la star"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E" />

    <RatingBar
        android:id="@+id/scoreIndicator"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/celebrityName"
        android:layout_toEndOf="@id/profilePhoto"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:numStars="5"
        android:stepSize="0.1"
        android:isIndicator="true"
        android:progressTint="#FFD700" />

    <TextView
        android:id="@+id/hiddenIdField"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/scoreIndicator"
        android:layout_toEndOf="@id/profilePhoto"
        android:layout_marginStart="16dp"
        android:visibility="gone" />

</RelativeLayout>